# ============================================
# CRM Tool - Staging Environment Configuration
# Copy this file to .env.staging and fill in your values
# ============================================

# PostgreSQL (staging database)
DATABASE_URL=postgresql://admin:changeme@localhost:5433/crm_db_staging?schema=public
POSTGRES_DB=crm_db_staging
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Redis (staging)
REDIS_URL=redis://:changeme@localhost:6380
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# IMAP TLS
IMAP_TLS_REJECT_UNAUTHORIZED=false

# Encryption (use same keys as production for consistency, or separate staging keys)
FERNET_KEY=replace_with_64_char_hex_string
ENCRYPTION_KEY=replace_with_64_char_hex_string

# Legacy salt
LEGACY_SALT=staging-legacy-salt

# Old encryption key for key rotation
OLD_FERNET_KEY=

# NextAuth
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace_with_32_char_random_string

# Cron Secret
CRON_SECRET=staging-cron-secret

# NVIDIA NIM API (optional)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# GitHub Token (optional)
GITHUB_TOKEN=

# Paid enrichment APIs (optional)
APOLLO_API_KEY=
HUNTER_API_KEY=

# Adapter mode: "mock" for fake data, "live" for real API calls
ADAPTER_MODE=mock

# Web App
WEB_PORT=3001

# BullMQ Board
BULL_BOARD_PORT=3011

# Bull Board auth
BULL_BOARD_USER=admin
BULL_BOARD_PASS=changeme

# Email defaults
DEFAULT_SMTP_HOST=smtp.gmail.com
DEFAULT_SMTP_PORT=587
DEFAULT_IMAP_HOST=imap.gmail.com
DEFAULT_IMAP_PORT=993

# LeadStealth integration
LEADSTEALTH_URL=http://localhost:8001
LEADSTEALTH_API_KEY=staging-key