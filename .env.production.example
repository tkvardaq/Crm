# ============================================
# CRM Tool - Production Environment Configuration
# Copy this file to .env.production and fill in your values
# NEVER commit this file to version control!
# ============================================

# PostgreSQL (use managed PostgreSQL in production: RDS, Cloud SQL, etc.)
DATABASE_URL=postgresql://user:password@host:5432/crm_db?schema=public&sslmode=require
POSTGRES_DB=crm_db
POSTGRES_USER=user
POSTGRES_PASSWORD=generate_strong_password
POSTGRES_PORT=5432

# Redis (use managed Redis in production: ElastiCache, Cloud Memorystore, etc.)
REDIS_URL=redis://:password@host:6379
REDIS_PORT=6379
REDIS_PASSWORD=generate_strong_password

# IMAP TLS
IMAP_TLS_REJECT_UNAUTHORIZED=true

# Encryption (generate with: openssl rand -hex 32)
# CRITICAL: Use the SAME key everywhere. Store in secret manager (AWS Secrets Manager, GCP Secret Manager, etc.)
FERNET_KEY=replace_with_64_char_hex_string_from_secret_manager
ENCRYPTION_KEY=replace_with_64_char_hex_string_from_secret_manager

# Legacy salt for decrypting old 3-part ciphertext (used during key rotation)
LEGACY_SALT=replace_with_random_string

# Old encryption key for key rotation (set when rotating to a new FERNET_KEY)
OLD_FERNET_KEY=

# NextAuth
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=generate_with_openssl_rand_hex_32

# Cron Secret (used to authenticate cron job requests)
CRON_SECRET=generate_strong_random_string

# NVIDIA NIM API (optional)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# GitHub Token (optional - increases rate limit)
GITHUB_TOKEN=

# Paid enrichment APIs (optional)
APOLLO_API_KEY=
HUNTER_API_KEY=

# Adapter mode: "mock" for fake data, "live" for real API calls
ADAPTER_MODE=live

# Web App
WEB_PORT=3000

# BullMQ Board
BULL_BOARD_PORT=3010

# Bull Board auth
BULL_BOARD_USER=admin
BULL_BOARD_PASS=generate_strong_password

# Email defaults
DEFAULT_SMTP_HOST=smtp.sendgrid.net
DEFAULT_SMTP_PORT=587
DEFAULT_IMAP_HOST=imap.sendgrid.net
DEFAULT_IMAP_PORT=993

# LeadStealth integration
LEADSTEALTH_URL=http://leadstealth:8001
LEADSTEALTH_API_KEY=generate_strong_random_key

# Domain configuration (for Traefik SSL)
DOMAIN=app.yourdomain.com
BULL_BOARD_DOMAIN=bull.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# GitHub Container Registry
GITHUB_REPOSITORY_OWNER=your-github-org