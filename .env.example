# ============================================
# CRM Tool - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://admin:changeme@localhost:5432/crm_db?schema=public
POSTGRES_DB=crm_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://:changeme@localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# IMAP TLS (set to "false" only for self-signed certs in dev)
IMAP_TLS_REJECT_UNAUTHORIZED=true

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
FERNET_KEY=replace_with_a_64_char_hex_string
ENCRYPTION_KEY=replace_with_a_64_char_hex_string

# Legacy salt for decrypting old 3-part ciphertext (used during key rotation)
LEGACY_SALT=dev-legacy-salt-change-in-production

# Old encryption key for key rotation (set when rotating to a new FERNET_KEY)
OLD_FERNET_KEY=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_random_secret_min_32_chars

# Cron Secret (used to authenticate cron job requests)
CRON_SECRET=replace_with_a_random_secret

# NVIDIA NIM API (optional - for AI-powered features and enrichment)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# GitHub Token (optional - increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Paid enrichment APIs (optional - free adapters are used by default)
APOLLO_API_KEY=
HUNTER_API_KEY=

# Adapter mode: "mock" for fake data, "live" for real API calls
ADAPTER_MODE=live

# Web App
WEB_PORT=3000

# BullMQ Board
BULL_BOARD_PORT=3010

# Bull Board auth
BULL_BOARD_USER=admin
BULL_BOARD_PASS=replace_with_a_strong_password

# Email defaults
DEFAULT_SMTP_HOST=smtp.gmail.com
DEFAULT_SMTP_PORT=587
DEFAULT_IMAP_HOST=imap.gmail.com
DEFAULT_IMAP_PORT=993

# LeadStealth integration
LEADSTEALTH_URL=http://localhost:8001
LEADSTEALTH_API_KEY=replace_with_strong_random_key

# LeadStealth integration
LEADSTEALTH_URL=http://leadstealth:8001
LEADSTEALTH_API_KEY=replace_with_strong_random_key
