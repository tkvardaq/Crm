# ============================================
# CRM Tool - Environment Configuration
# Copy this file to apps/web/.env.local
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://admin:changeme@localhost:5432/crm_db?schema=public
POSTGRES_DB=crm_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://:changeme@localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
FERNET_KEY=replace_with_a_64_char_hex_string
ENCRYPTION_KEY=replace_with_a_64_char_hex_string
LEGACY_SALT=replace_with_a_random_string

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_random_secret_min_32_chars

# Cron Secret
CRON_SECRET=replace_with_a_random_secret

# AI (optional)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Enrichment APIs (optional)
APOLLO_API_KEY=
HUNTER_API_KEY=
ADAPTER_MODE=mock

# Services
WEB_PORT=3000
BULL_BOARD_PORT=3010
BULL_BOARD_USER=admin
BULL_BOARD_PASS=replace_with_a_strong_password

# Email defaults
DEFAULT_SMTP_HOST=smtp.gmail.com
DEFAULT_SMTP_PORT=587
DEFAULT_IMAP_HOST=imap.gmail.com
DEFAULT_IMAP_PORT=993

# LeadStealth scraper service
LEADSTEALTH_URL=http://localhost:8001
LEADSTEALTH_API_KEY=replace_with_strong_random_key
